{
  "entities": {
    "Service": {
      "title": "Salon Service",
      "description": "A beauty or henna service offered by the salon.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string", "enum": ["henna", "beauty", "hair_removal"] },
        "imageUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Product": {
      "title": "Beauty Product",
      "description": "Products used or sold by the salon.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "imageUrl"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image for the portfolio gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["bridal", "traditional", "modern"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl"]
    },
    "Promotion": {
      "title": "Salon Promotion",
      "description": "Special offers and discounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discount": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" }
      },
      "required": ["title", "discount"]
    },
    "AppSettings": {
      "title": "Application Settings",
      "description": "General application configuration.",
      "type": "object",
      "properties": {
        "heroImageUrl": { "type": "string" }
      }
    },
    "Stats": {
      "title": "Analytics Stats",
      "description": "Site statistics.",
      "type": "object",
      "properties": {
        "count": { "type": "number" }
      }
    }
  },
  "firestore": {
    "services": {
      "schema": "Service",
      "description": "Collection of services offered by the salon."
    },
    "products": {
      "schema": "Product",
      "description": "Collection of products used/displayed."
    },
    "gallery": {
      "schema": "GalleryImage",
      "description": "Portfolio images."
    },
    "promotions": {
      "schema": "Promotion",
      "description": "Active offers."
    },
    "settings": {
      "schema": "AppSettings",
      "description": "Global application configuration."
    },
    "stats": {
      "schema": "Stats",
      "description": "General statistics."
    }
  }
}
