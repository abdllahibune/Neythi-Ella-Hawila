rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promotions
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Stats
    match /stats/{statId} {
      allow read: if true;
      allow write: if true; // Allowed for incrementing visits
    }
    
    // Admins collection (if manually added)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
